---
interface Props {
  sectionId: string;
  eyebrow: string;
  title: string;
  description: string;
  note: string;
}

const {
  sectionId,
  eyebrow,
  title,
  description,
  note,
} = Astro.props as Props;
---

<section class="interactive-proof interactive-shell" aria-labelledby={sectionId}>
  <div class="interactive-copy">
    <p class="interactive-eyebrow">{eyebrow}</p>
    <h2 id={sectionId} class="interactive-title">{title}</h2>
    <p class="interactive-description">{description}</p>
  </div>

  <div class="interactive-canvas">
    <slot />
  </div>

  <p class="interactive-note">{note}</p>
</section>

<style>
  .interactive-shell {
    max-width: min(var(--container-max), 100%);
    margin: var(--space-24) auto 0;
    padding-top: var(--space-16);
    border-top: 1px solid var(--color-bg-muted);
    display: grid;
    gap: var(--space-8);
  }

  .interactive-copy {
    display: grid;
    gap: var(--space-3);
    max-width: var(--container-prose);
    margin-inline: auto;
  }

  .interactive-eyebrow {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .interactive-title {
    font-size: var(--text-xl);
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .interactive-description {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .interactive-canvas {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-bg-muted);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .interactive-note {
    max-width: var(--container-prose);
    margin-inline: auto;
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: var(--text-sm);
  }

  @media (min-width: 900px) {
    .interactive-canvas {
      padding: var(--space-8);
    }
  }
</style>
