---
import { ArrowRight, Clock3, Mail } from 'lucide-preact';
import ContactForm from '../islands/ContactForm.tsx';

const WHATSAPP_NUMBER = '+529992197979';
const WHATSAPP_MESSAGE =
	'Hola Gadiel, vi tu portafolio y me interesa platicar sobre un sitio web para mi negocio.';
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`;

const EMAIL = 'uicabgadiel67@correo.com';
const EMAIL_SUBJECT = 'Consulta sobre sitio web';
const EMAIL_BODY = `Hola Gadiel,

Vi tu portafolio y me interesa cotizar un sitio web.

Tipo de proyecto:
Objetivo principal:
Fecha estimada:
Referencias o enlaces:

Quedo atento.`;
const EMAIL_URL = `mailto:${EMAIL}?subject=${encodeURIComponent(EMAIL_SUBJECT)}&body=${encodeURIComponent(EMAIL_BODY)}`;

---

<section
	id="contacto"
	aria-labelledby="contact-heading"
	class="contact-section"
>
	<div class="container contact-shell">
		<div class="contact-copy">
			<p class="contact-eyebrow">Contacto</p>

			<h2 id="contact-heading" class="contact-title">
				Hablemos de tu sitio antes de hablar de infraestructura.
			</h2>

			<p class="contact-description">
				Hoy mi oferta principal es web: sitios para negocio, landing pages y portafolios profesionales.
				Si tu proyecto encaja en eso, el canal m&aacute;s r&aacute;pido sigue siendo WhatsApp.
			</p>

			<div class="contact-methods" role="group" aria-label="Canales de contacto">
				<a
					href={WHATSAPP_URL}
					class="contact-action contact-action--primary"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Escribirme por WhatsApp para cotizar un sitio web"
				>
					<svg
						class="contact-whatsapp-icon"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
					</svg>
					<span>Escribirme por WhatsApp</span>
				</a>

				<a
					href={EMAIL_URL}
					class="contact-action contact-action--secondary"
					aria-label="Enviar brief por correo con asunto y mensaje prellenado"
				>
					<Mail size={18} />
					<span>Enviar brief por correo</span>
				</a>
			</div>

			<ul class="contact-signals" role="list">
				<li>
					<Clock3 size={16} />
					<span>Canales activos hoy: WhatsApp y correo.</span>
				</li>
				<li>
					<ArrowRight size={16} />
					<span>Proyectos ideales: sitio web, landing page o portafolio profesional.</span>
				</li>
			</ul>
		</div>

		<div class="contact-brief contact-brief-surface" aria-labelledby="contact-brief-title">
			<h3 id="contact-brief-title" class="sr-only">Formulario de contacto</h3>
			<ContactForm client:idle />
		</div>
	</div>
</section>

<style>
	.contact-section {
		position: relative;
		overflow: hidden;
		border-top: 1px solid var(--color-bg-muted);
		padding: var(--space-24) 0;
		background:
			radial-gradient(circle at top left, var(--color-accent-subtle) 0, transparent 38%),
			linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-subtle) 100%);
	}

	.contact-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(to right, transparent, transparent calc(100% - 1px), var(--color-bg-muted) calc(100% - 1px)),
			linear-gradient(to bottom, transparent, transparent calc(100% - 1px), var(--color-bg-muted) calc(100% - 1px));
		background-size: 120px 120px;
		opacity: 0.2;
		pointer-events: none;
	}

	.contact-shell {
		position: relative;
		z-index: 1;
		display: grid;
		gap: var(--space-12);
		align-items: start;
	}

	.contact-copy,
	.contact-brief {
		display: grid;
		gap: var(--space-6);
	}

	.contact-brief-surface {
		padding: var(--space-3);
		border: 1px solid color-mix(in srgb, var(--color-bg-muted) 84%, transparent);
		border-radius: calc(var(--radius-lg) + var(--space-2));
		background: color-mix(in srgb, var(--color-surface) 72%, transparent);
		box-shadow: 0 24px 90px color-mix(in srgb, var(--color-text-primary) 10%, transparent);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.contact-eyebrow,
	.contact-brief-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-secondary);
	}

	.contact-title {
		max-width: 12ch;
		font-size: var(--text-4xl);
		line-height: 1.05;
	}

	.contact-description {
		max-width: 56ch;
		font-size: var(--text-lg);
		line-height: 1.8;
		color: var(--color-text-secondary);
	}

	.contact-methods {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
	}

	.contact-action {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3);
		min-height: 48px;
		padding: var(--space-3) var(--space-6);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-bg-muted);
		font-size: var(--text-sm);
		font-weight: 500;
		text-decoration: none;
		transition: transform 150ms ease, border-color 150ms ease, background 150ms ease;
	}

	.contact-action:hover {
		transform: translateY(-1px);
	}

	.contact-whatsapp-icon {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
	}

	.contact-action--primary {
		background: var(--color-whatsapp);
		border-color: var(--color-whatsapp);
		color: #052e16;
	}

	.contact-action--primary:hover {
		background: var(--color-whatsapp-hover);
		border-color: var(--color-whatsapp-hover);
		color: #052e16;
	}

	.contact-action--secondary {
		background: var(--color-bg);
		color: var(--color-text-primary);
	}

	.contact-action--secondary:hover {
		border-color: var(--color-text-secondary);
		background: var(--color-bg-subtle);
	}

	.contact-signals {
		list-style: none;
		display: grid;
		gap: var(--space-4);
		max-width: 58ch;
	}

	.contact-signals li {
		display: flex;
		align-items: flex-start;
		gap: var(--space-3);
		padding-top: var(--space-4);
		border-top: 1px solid color-mix(in srgb, var(--color-bg-muted) 80%, transparent);
		color: var(--color-text-secondary);
	}

	.contact-signals svg {
		flex-shrink: 0;
		margin-top: 0.2rem;
		color: var(--color-accent);
	}

	@media (min-width: 960px) {
		.contact-shell {
			grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
		}

		.contact-title {
			font-size: var(--text-6xl);
		}
	}
</style>
