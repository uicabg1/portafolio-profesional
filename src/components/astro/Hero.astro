---
const NAME = 'Gadiel Uicab';
const VALUE_PROP = 'Sitios web claros para negocios que necesitan verse serios y facilitar el contacto.';
const DESCRIPTION = `Soy estudiante de segundo semestre de Ingenieria de Software en la UADY y TIDE Fellow 2026.
Desarrollo sitios web, landing pages y portafolios profesionales con foco en claridad, rendimiento y mantenimiento.`;

const WHATSAPP_NUMBER = '+529992197979';
const WHATSAPP_MESSAGE = `Hola ${NAME}, vi tu portafolio y me interesa cotizar un sitio web para mi negocio.`;
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`;

const proofItems = [
	{
		label: 'Oferta activa',
		value: 'Sitios web, landing pages y portafolios profesionales.',
	},
		{
			label: 'Canal rapido',
			value: 'WhatsApp como canal principal y formulario como apoyo cuando necesitas mas contexto.',
		},
	{
		label: 'Base tecnica',
		value: 'UADY, TIDE Fellows y certificacion LACNIC IPv6 basico.',
	},
		{
			label: 'En progreso',
			value: 'IPv6 avanzado, gestion de redes y preparacion documentada hacia VPS real post-Sprint 4.',
		},
];

const STACK = ['Astro', 'TypeScript', 'Tailwind v4', 'MDX', 'Preact Islands', 'Linux'];
---

<section
	id="hero"
	role="region"
	aria-labelledby="hero-heading"
	class="hero-section"
>
	<div class="container hero-inner">
		<div class="hero-copy">
			<div class="hero-eyebrow" aria-label="Contexto profesional">
				<span class="eyebrow-badge">
					<span class="status-dot" aria-hidden="true"></span>
					Web-first · UADY · TIDE Fellows · Merida, MX
				</span>
			</div>

			<h1 id="hero-heading" class="hero-title">{VALUE_PROP}</h1>

			<p class="hero-description">{DESCRIPTION}</p>

				<p class="hero-support">
					Hoy la oferta es web-first. La capa de infraestructura y redes aparece como respaldo tecnico
					para tomar mejores decisiones, no como una promesa de servicios que aun no toca operar en produccion.
				</p>

			<div class="hero-ctas" role="group" aria-label="Acciones principales">
				<a
					href={WHATSAPP_URL}
					class="btn-whatsapp-hero"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Cotizar por WhatsApp con ${NAME} (abre WhatsApp en nueva pestana)`}
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
					</svg>
					Cotizar por WhatsApp
				</a>

				<a
					href="/#proyectos"
					class="btn-secondary"
					aria-label={`Ver casos de estudio de ${NAME}`}
				>
					Ver casos de estudio
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M5 12h14M12 5l7 7-7 7"/>
					</svg>
				</a>
			</div>
		</div>

		<div class="hero-details" aria-label="Señales de confianza">
			<div class="hero-proof" role="list">
				{proofItems.map(({ label, value }) => (
					<article class="hero-proof-item" role="listitem">
						<p class="hero-proof-label">{label}</p>
						<p class="hero-proof-value">{value}</p>
					</article>
				))}
			</div>

			<div class="hero-stack" aria-label="Herramientas actuales">
				<p class="stack-label">Herramientas actuales</p>
				<ul role="list" class="stack-list">
					{STACK.map((tech) => (
						<li class="stack-badge">{tech}</li>
					))}
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		position: relative;
		overflow: hidden;
		min-height: 100vh;
		min-height: 100svh;
		display: flex;
		align-items: center;
		padding: var(--space-16) 0;
		padding-top: calc(60px + var(--space-12));
		background:
			radial-gradient(circle at top right, var(--color-accent-subtle) 0, transparent 34%),
			linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-bg-subtle) 72%, transparent) 100%);
	}

	.hero-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(to right, transparent, transparent calc(100% - 1px), var(--color-bg-muted) calc(100% - 1px)),
			linear-gradient(to bottom, transparent, transparent calc(100% - 1px), var(--color-bg-muted) calc(100% - 1px));
		background-size: 96px 96px;
		opacity: 0.16;
		pointer-events: none;
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		display: grid;
		gap: var(--space-12);
		align-items: end;
	}

	.hero-copy,
	.hero-details {
		display: grid;
		gap: var(--space-6);
	}

	.hero-eyebrow {
		display: flex;
		align-items: center;
	}

	.eyebrow-badge {
		display: inline-flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-2);
		max-width: 100%;
		padding: var(--space-1) var(--space-3);
		background: color-mix(in srgb, var(--color-bg) 82%, transparent);
		border: 1px solid var(--color-bg-muted);
		border-radius: var(--radius-full);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		letter-spacing: 0.04em;
	}

	.status-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--color-success);
		animation: pulse 2s ease-in-out infinite;
	}

	@media (prefers-reduced-motion: reduce) {
		.status-dot {
			animation: none;
		}
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.55; transform: scale(0.88); }
	}

	.hero-title {
		max-width: min(11ch, 100%);
		font-size: var(--text-4xl);
		line-height: 0.98;
		letter-spacing: -0.03em;
		overflow-wrap: break-word;
		text-wrap: balance;
	}

	.hero-description,
	.hero-support {
		max-width: min(58ch, 100%);
		font-size: var(--text-lg);
		line-height: 1.8;
		color: var(--color-text-secondary);
	}

	.hero-support {
		max-width: min(60ch, 100%);
		font-size: var(--text-base);
	}

	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-4);
	}

	.btn-whatsapp-hero,
	.btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		min-height: 48px;
		padding: var(--space-3) var(--space-6);
		border-radius: var(--radius-md);
		font-size: var(--text-base);
		text-decoration: none;
		transition: transform 120ms ease, border-color 150ms ease, background 150ms ease;
	}

	.btn-whatsapp-hero:hover,
	.btn-secondary:hover {
		transform: translateY(-1px);
	}

	.btn-whatsapp-hero {
		background: var(--color-whatsapp);
		color: #052e16;
	}

	.btn-whatsapp-hero:hover {
		background: var(--color-whatsapp-hover);
		color: #052e16;
	}

	.btn-secondary {
		border: 1px solid var(--color-bg-muted);
		color: var(--color-text-primary);
		background: color-mix(in srgb, var(--color-bg) 82%, transparent);
	}

	.btn-secondary:hover {
		border-color: var(--color-text-secondary);
		background: var(--color-bg-subtle);
	}

	.hero-proof {
		display: grid;
		gap: var(--space-6);
	}

	.hero-proof-item {
		display: grid;
		gap: var(--space-2);
		padding-top: var(--space-4);
		border-top: 1px solid color-mix(in srgb, var(--color-bg-muted) 80%, transparent);
	}

	.hero-proof-label,
	.stack-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-secondary);
	}

	.hero-proof-value {
		max-width: 28ch;
		line-height: 1.8;
		color: var(--color-text-primary);
	}

	.hero-stack {
		display: grid;
		gap: var(--space-4);
		padding-top: var(--space-2);
	}

	.stack-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.stack-badge {
		padding: var(--space-2) var(--space-3);
		border-radius: var(--radius-full);
		border: 1px solid var(--color-bg-muted);
		background: color-mix(in srgb, var(--color-bg) 82%, transparent);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
	}

	@media (min-width: 768px) {
		.hero-proof {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 960px) {
		.hero-inner {
			grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
		}

		.hero-title {
			font-size: var(--text-6xl);
		}
	}
</style>
