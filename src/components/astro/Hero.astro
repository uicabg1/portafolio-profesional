---
import { ArrowRight } from 'lucide-preact';

const NAME = 'Gadiel Uicab';
const VALUE_PROP = 'Sitios web claros para negocios que necesitan verse serios y facilitar el contacto.';
const DESCRIPTION = `Soy estudiante de segundo semestre de Ingenieria de Software en la UADY y TIDE Fellow 2026.
Desarrollo sitios web, landing pages y portafolios profesionales con foco en claridad, rendimiento y mantenimiento.`;

const WHATSAPP_NUMBER = '+529992197979';
const WHATSAPP_MESSAGE = `Hola ${NAME}, vi tu portafolio y me interesa cotizar un sitio web para mi negocio.`;
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`;

const HERO_SIGNALS = [
	{
		kicker: '01 / Oferta',
		title: 'Web-first',
		detail: 'Sitios, landing pages y portafolios con CTA claro.',
	},
	{
		kicker: '02 / Evidencia',
		title: 'Casos interactivos',
		detail: 'RSA, IPv6, MDX y proyectos navegables como prueba real.',
	},
	{
		kicker: '03 / Operacion',
		title: 'VPS dual-stack',
		detail: 'Publicacion real con HTTPS, CI/CD, IPv4 e IPv6.',
	},
];

const SIGNAL_STACK = ['Astro', 'Preact Islands', 'MDX', 'VPS', 'IPv6'];
---

<section
	id="hero"
	role="region"
	aria-labelledby="hero-heading"
	class="hero-section"
>
	<div class="container hero-inner">
		<div class="hero-copy">
			<p class="hero-kicker">Web-first / Infraestructura como evidencia</p>

			<p class="hero-identity">{NAME}</p>

			<h1 id="hero-heading" class="hero-title">{VALUE_PROP}</h1>

			<p class="hero-description">{DESCRIPTION}</p>

			<p class="hero-support">
				La capa de infraestructura, redes y operacion no desplaza la oferta principal: la hace mas
				confiable cuando el proyecto necesita criterio tecnico desde el inicio.
			</p>

			<div class="hero-ctas" role="group" aria-label="Acciones principales">
				<a
					href={WHATSAPP_URL}
					class="btn-whatsapp-hero"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Cotizar por WhatsApp con ${NAME} (abre WhatsApp en nueva pestana)`}
				>
					<svg
						class="whatsapp-icon"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
					</svg>
					Cotizar por WhatsApp
				</a>

				<a
					href="/#proyectos"
					class="btn-secondary"
					aria-label={`Ver casos de estudio de ${NAME}`}
				>
					Ver casos de estudio
					<ArrowRight size={16} aria-hidden="true" />
				</a>
			</div>
		</div>

		<div class="hero-visual" aria-label="Mapa tecnico de evidencia del portafolio">
			<div class="hero-signal-map" role="list">
				{HERO_SIGNALS.map(({ kicker, title, detail }) => (
					<article class="hero-signal" role="listitem">
						<p class="hero-signal-kicker">{kicker}</p>
						<h2 class="hero-signal-title">{title}</h2>
						<p class="hero-signal-detail">{detail}</p>
					</article>
				))}
			</div>

			<div class="hero-visual-axis" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</div>

			<div class="hero-stack-signal" aria-label="Stack tecnico visible">
				<p class="hero-stack-label">Stack visible</p>
				<ul role="list" class="hero-stack-list">
					{SIGNAL_STACK.map((tech) => (
						<li>{tech}</li>
					))}
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		min-height: 92vh;
		min-height: 92svh;
		padding: calc(60px + var(--space-10, var(--space-8))) 0 var(--space-16);
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--color-accent-subtle) 72%, transparent) 0, transparent 42%),
			linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-subtle) 100%);
	}

	.hero-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(to right, transparent, transparent calc(100% - 1px), var(--color-bg-muted) calc(100% - 1px)),
			linear-gradient(to bottom, transparent, transparent calc(100% - 1px), var(--color-bg-muted) calc(100% - 1px));
		background-size: 112px 112px;
		opacity: 0.12;
		pointer-events: none;
	}

	.hero-section::after {
		content: '';
		position: absolute;
		right: max(-18vw, -160px);
		bottom: max(-22vw, -220px);
		width: min(54vw, 620px);
		aspect-ratio: 1;
		border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
		border-radius: 50%;
		opacity: 0.45;
		pointer-events: none;
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		display: grid;
		gap: var(--space-12);
		align-items: center;
	}

	.hero-copy {
		display: grid;
		gap: var(--space-6);
		max-width: 760px;
	}

	.hero-kicker,
	.hero-stack-label,
	.hero-signal-kicker {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.hero-identity {
		max-width: none;
		font-family: var(--font-display);
		font-size: clamp(3.4rem, 14vw, 9.5rem);
		line-height: 0.92;
		color: var(--color-text-primary);
		text-wrap: balance;
	}

	.hero-title {
		max-width: min(17ch, 100%);
		font-size: clamp(2.35rem, 7vw, var(--text-6xl));
		line-height: 1.06;
		overflow-wrap: break-word;
		text-wrap: balance;
	}

	.hero-description,
	.hero-support {
		max-width: min(62ch, 100%);
		font-size: var(--text-lg);
		line-height: 1.75;
		color: var(--color-text-secondary);
	}

	.hero-support {
		font-size: var(--text-base);
	}

	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-4);
		padding-top: var(--space-2);
	}

	.btn-whatsapp-hero,
	.btn-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-2);
		min-height: 48px;
		padding: var(--space-3) var(--space-6);
		border-radius: var(--radius-md);
		font-size: var(--text-base);
		font-weight: 500;
		text-decoration: none;
		transition: transform 140ms ease, border-color 150ms ease, background 150ms ease, color 150ms ease;
	}

	.btn-whatsapp-hero:hover,
	.btn-secondary:hover {
		transform: translateY(-1px);
	}

	.btn-whatsapp-hero {
		background: var(--color-whatsapp);
		color: #052e16;
	}

	.whatsapp-icon {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
	}

	.btn-whatsapp-hero:hover {
		background: var(--color-whatsapp-hover);
		color: #052e16;
	}

	.btn-secondary {
		border: 1px solid var(--color-bg-muted);
		color: var(--color-text-primary);
		background: color-mix(in srgb, var(--color-bg) 76%, transparent);
	}

	.btn-secondary:hover {
		border-color: var(--color-text-secondary);
		background: var(--color-bg);
	}

	.hero-visual {
		position: relative;
		display: grid;
		gap: var(--space-8);
		min-height: 440px;
		padding: var(--space-6) 0;
	}

	.hero-signal-map {
		position: relative;
		display: grid;
		gap: var(--space-6);
	}

	.hero-signal-map::before {
		content: '';
		position: absolute;
		top: 28px;
		bottom: 28px;
		left: 18px;
		width: 1px;
		background: linear-gradient(180deg, transparent, var(--color-accent), transparent);
		opacity: 0.55;
	}

	.hero-signal {
		position: relative;
		display: grid;
		gap: var(--space-2);
		padding-left: var(--space-12);
	}

	.hero-signal::before {
		content: '';
		position: absolute;
		top: 0.55rem;
		left: 9px;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: var(--color-bg);
		border: 1px solid var(--color-accent);
		box-shadow: 0 0 0 7px color-mix(in srgb, var(--color-accent-subtle) 70%, transparent);
	}

	.hero-signal-title {
		font-family: var(--font-body);
		font-size: var(--text-xl);
		font-weight: 500;
		line-height: 1.2;
	}

	.hero-signal-detail {
		max-width: 36ch;
		line-height: 1.7;
		color: var(--color-text-secondary);
	}

	.hero-visual-axis {
		position: absolute;
		inset: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		z-index: -1;
		pointer-events: none;
	}

	.hero-visual-axis span {
		border-left: 1px solid color-mix(in srgb, var(--color-bg-muted) 70%, transparent);
		opacity: 0.5;
	}

	.hero-stack-signal {
		display: grid;
		gap: var(--space-4);
		padding-top: var(--space-4);
		border-top: 1px solid color-mix(in srgb, var(--color-bg-muted) 70%, transparent);
	}

	.hero-stack-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.hero-stack-list li {
		padding: var(--space-2) var(--space-3);
		border: 1px solid var(--color-bg-muted);
		border-radius: var(--radius-full);
		background: color-mix(in srgb, var(--color-bg) 78%, transparent);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
	}

	@media (prefers-reduced-motion: no-preference) {
		.hero-copy,
		.hero-visual {
			opacity: 0;
			transform: translateY(var(--space-4));
			animation: hero-rise 620ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
		}

		.hero-visual {
			animation-delay: 120ms;
		}
	}

	@keyframes hero-rise {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (min-width: 960px) {
		.hero-section {
			min-height: 94vh;
			min-height: 94svh;
		}

		.hero-inner {
			grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
			gap: var(--space-16);
		}

		.hero-copy {
			max-width: 720px;
		}
	}
</style>
