---
import { ArrowRight, Gauge, Globe, PanelsTopLeft, Server } from 'lucide-preact';

const services = [
	{
		number: '01',
		title: 'Sitios web para negocio',
		icon: Globe,
		description:
			'Presencia web clara para explicar tu oferta, verse serio y convertir visitas en conversaciones reales.',
		idealFor: 'Negocios pequenos o medianos que necesitan una base publica profesional sin complejidad innecesaria.',
		deliverables: [
			'Estructura one-page o multipagina segun alcance',
			'Copy organizado para servicios, beneficios y confianza',
			'CTA visibles hacia WhatsApp, correo o formulario',
		],
	},
	{
		number: '02',
		title: 'Landing pages y portafolios profesionales',
		icon: PanelsTopLeft,
		description:
			'Paginas enfocadas en una accion concreta: presentar una idea, lanzar un servicio o mostrar trabajo con narrativa.',
		idealFor: 'Profesionales, estudiantes o proyectos que necesitan una pagina publica mas creible y mejor presentada.',
		deliverables: [
			'Jerarquia visual para desktop y mobile',
			'Casos de estudio o muestras de trabajo integradas',
			'Metadata, rutas y estructura listas para compartir',
		],
	},
	{
		number: '03',
		title: 'Mejora tecnica y publicacion',
		icon: Gauge,
		description:
			'Refactor visual, estructura, rendimiento y preparacion de salida estatica para sitios que ya existen.',
		idealFor: 'Sitios que cargan lento, se sienten compactos o necesitan quedar listos para una publicacion mas ordenada.',
		deliverables: [
			'Auditoria de estructura, contenido y navegacion',
			'Ajustes de semantica, performance y experiencia movil',
			'Documentacion basica para mantenimiento y entrega',
		],
	},
];
---

<section
	id="servicios"
	aria-labelledby="services-heading"
	class="services-section editorial-section services-editorial"
>
	<div class="container services-shell">
		<header class="services-intro motion-rise">
			<p class="section-kicker">Servicios activos</p>

			<h2 id="services-heading" class="editorial-title services-title">
				Web primero. Oferta clara y evidencia real.
			</h2>

			<p class="services-description">
				Sitios publicables, landing pages y mejoras tecnicas con una lectura comercial simple desde el primer scroll.
			</p>
		</header>

		<div class="services-list">
			{services.map(({ number, title, icon: Icon, description, idealFor, deliverables }) => (
				<article class="service-proof-row">
					<div class="service-index" aria-hidden="true">
						<span>{number}</span>
						<Icon size={20} />
					</div>

					<div class="service-copy">
						<p class="service-label">Oferta activa</p>
						<h3>{title}</h3>
						<p>{description}</p>

						<ul class="service-signals" role="list" aria-label={`Senales visibles de ${title}`}>
							{deliverables.slice(0, 2).map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</div>

					<details class="service-disclosure">
						<summary>Ver alcance</summary>
						<p>{idealFor}</p>

						<ul role="list">
							{deliverables.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</details>
				</article>
			))}
		</div>

		<aside class="service-future-scope" aria-label="Capacidad tecnica complementaria">
			<div class="service-future-icon">
				<Server size={20} />
			</div>

			<div class="service-future-copy">
				<p class="section-kicker">Capacidad complementaria</p>
				<h3>VPS, IPv6, Nginx y CI/CD.</h3>
				<p>Operacion real como evidencia tecnica para proyectos web.</p>
			</div>

			<details class="service-disclosure service-disclosure--future">
				<summary>Ver evidencia operacional</summary>
				<p>
					Esta capa se activa cuando el proyecto necesita despliegue documentado, dual-stack, Nginx
					y CI/CD con trazabilidad real.
				</p>
			</details>

			<a href="/#contacto" class="service-future-link">
				Convertir una necesidad web en brief
				<ArrowRight size={16} />
			</a>
		</aside>
	</div>
</section>

<style>
	.services-section {
		border-top: 1px solid var(--color-bg-muted);
		background:
			linear-gradient(90deg, color-mix(in srgb, var(--color-surface-strong) 58%, transparent) 0 1px, transparent 1px),
			linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-subtle) 100%);
		background-size: 96px 100%, auto;
	}

	.services-shell {
		display: grid;
		gap: var(--space-16);
	}

	.services-intro {
		display: grid;
		gap: var(--space-6);
		max-width: 860px;
	}

	.services-title {
		max-width: min(18ch, 100%);
		text-align: left;
	}

	.services-description {
		max-width: 64ch;
		font-size: var(--text-lg);
		line-height: 1.82;
		color: var(--color-text-secondary);
	}

	.services-list {
		display: grid;
		border-top: 1px solid var(--color-bg-muted);
	}

	.service-proof-row {
		display: grid;
		gap: var(--space-8);
		padding-block: var(--space-12);
		border-bottom: 1px solid var(--color-bg-muted);
	}

	.service-index {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		color: var(--color-signal-cyan);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.service-copy,
	.service-future-copy,
	.service-disclosure {
		display: grid;
		gap: var(--space-4);
	}

	.service-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.service-copy h3,
	.service-future-copy h3 {
		font-size: var(--text-2xl);
		line-height: 1.12;
	}

	.service-copy p,
	.service-disclosure p,
	.service-future-copy p {
		color: var(--color-text-secondary);
		line-height: 1.8;
	}

	.service-signals {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		list-style: none;
	}

	.service-signals li {
		padding: var(--space-2) var(--space-3);
		border: 1px solid var(--color-bg-muted);
		border-radius: var(--radius-full);
		background: color-mix(in srgb, var(--color-surface) 82%, transparent);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
	}

	.service-disclosure {
		padding-top: var(--space-1);
	}

	.service-disclosure summary {
		cursor: pointer;
		width: fit-content;
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--color-text-primary);
	}

	.service-disclosure summary::-webkit-details-marker {
		display: none;
	}

	.service-disclosure ul {
		display: grid;
		gap: var(--space-3);
		list-style: none;
	}

	.service-disclosure li {
		position: relative;
		padding-left: calc(var(--space-4) + var(--space-1));
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.service-disclosure li::before {
		content: '';
		position: absolute;
		top: 0.72rem;
		left: 0;
		width: 7px;
		height: 7px;
		border-radius: var(--radius-full);
		background: var(--color-signal-green);
	}

	.service-future-scope {
		display: grid;
		gap: var(--space-6);
		padding: var(--space-8);
		border-left: 4px solid var(--color-signal-amber);
		background: color-mix(in srgb, var(--color-surface) 86%, transparent);
		box-shadow: 0 24px 80px color-mix(in srgb, var(--color-text-primary) 8%, transparent);
	}

	.service-future-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-signal-amber) 14%, var(--color-bg));
		color: var(--color-signal-amber);
	}

	.service-future-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		width: fit-content;
		min-height: 48px;
		color: var(--color-accent);
		font-size: var(--text-sm);
		font-weight: 500;
	}

	@media (min-width: 900px) {
		.service-proof-row {
			grid-template-columns: 96px minmax(0, 1.05fr) minmax(300px, 0.95fr);
			align-items: start;
		}

		.service-index {
			display: grid;
			justify-items: start;
		}

		.service-future-scope {
			grid-template-columns: auto minmax(0, 1fr);
			align-items: start;
		}

		.service-future-icon {
			grid-column: 1;
			grid-row: 1;
		}

		.service-future-copy {
			grid-column: 2;
			grid-row: 1;
		}

		.service-disclosure--future {
			grid-column: 2;
			grid-row: 2;
			max-width: 60ch;
		}

		.service-future-link {
			grid-column: 2;
			grid-row: 3;
		}
	}
</style>
