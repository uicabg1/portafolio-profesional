---
const systemFlow = [
  {
    title: 'Astro Build',
    status: 'Static output',
    detail: 'Genera HTML, CSS y JS en build-time para una salida determinista.',
  },
  {
    title: 'GitHub Actions CI/CD',
    status: 'Deploy automatizado',
    detail: 'Compila y publica artefactos por SSH/rsync hacia el VPS.',
  },
  {
    title: 'VPS Linux',
    status: 'Servidor propio',
    detail: 'Opera el sitio en infraestructura controlada con usuario de deploy.',
  },
  {
    title: 'Nginx + HTTPS',
    status: 'Entrega segura',
    detail: 'Sirve el sitio estático con TLS y superficie reducida.',
  },
  {
    title: 'IPv4 / IPv6',
    status: 'Dual-stack validado',
    detail: 'Permite validar conectividad pública por ambos stacks.',
  },
];

const evidenceTracks = [
  {
    title: 'Static-first',
    detail:
      'El sitio evita runtime de aplicacion en produccion y convierte contenido, estilos y rutas en artefactos estaticos verificables.',
  },
  {
    title: 'Networking e IPv6',
    detail:
      'La capa dual-stack permite hablar de direccionamiento, DNS, reachability y transicion IPv6 desde una implementacion concreta.',
  },
  {
    title: 'Criterio NOC',
    detail:
      'La narrativa operacional prioriza monitoreo, trazabilidad, diagnostico inicial y recuperacion controlada ante cambios.',
  },
  {
    title: 'Seguridad y performance',
    detail:
      'Menos superficie de ataque, cacheabilidad, HTTPS y JavaScript limitado a islas con valor real.',
  },
];
---

<section
	id="infraestructura"
	aria-labelledby="infra-heading"
	class="infra-section editorial-section"
>
	<div class="container infra-shell">
		<header class="infra-header motion-rise">
			<p class="section-kicker">Infraestructura</p>
			<h2 id="infra-heading" class="editorial-title infra-title">
				Una cadena operacional que respalda la propuesta web.
			</h2>
			<p>
				Evidencia tecnica visible de build, despliegue, entrega segura y conectividad publica.
			</p>
		</header>

		<div class="infra-system-flow" role="list" aria-label="Flujo operacional del sistema">
			{systemFlow.map((node, index) => (
				<article class="infra-system-node" role="listitem">
					<div class="infra-system-index" aria-hidden="true">
						{String(index + 1).padStart(2, '0')}
					</div>

					<div class="infra-system-copy">
						<h3>{node.title}</h3>
						<p class="infra-system-status">{node.status}</p>
						<details class="infra-disclosure">
							<summary>Ver evidencia</summary>
							<p>{node.detail}</p>
						</details>
					</div>
				</article>
			))}
		</div>

		<div class="infra-evidence-grid" role="list" aria-label="Criterios tecnicos que demuestra la infraestructura">
			{evidenceTracks.map((track) => (
				<article class="infra-evidence-item" role="listitem">
					<h3>{track.title}</h3>
					<details class="infra-disclosure">
						<summary>Ver evidencia</summary>
						<p>{track.detail}</p>
					</details>
				</article>
			))}
		</div>

		<aside class="infra-note" aria-label="Alcance comercial actual">
			<p class="section-kicker">Lectura comercial honesta</p>
			<p>
				CI/CD, VPS, Nginx, HTTPS e IPv6 aumentan confianza tecnica. La oferta activa sigue siendo web-first:
				sitios, landing pages y mejoras visuales que se pueden sostener hoy con evidencia.
			</p>
		</aside>
	</div>
</section>

<style>
	.infra-section {
		position: relative;
		overflow: hidden;
		border-top: 1px solid var(--color-bg-muted);
		background:
			radial-gradient(circle at 80% 0%, color-mix(in srgb, var(--color-signal-green) 14%, transparent), transparent 34%),
			var(--color-bg);
	}

	.infra-shell {
		display: grid;
		gap: var(--space-16);
	}

	.infra-header {
		display: grid;
		gap: var(--space-6);
		max-width: 860px;
	}

	.infra-header p:not(.section-kicker) {
		max-width: 66ch;
		font-size: var(--text-lg);
		line-height: 1.85;
		color: var(--color-text-secondary);
	}

	.infra-system-flow {
		position: relative;
		display: grid;
		gap: var(--space-6);
	}

	.infra-system-flow::before {
		content: '';
		position: absolute;
		top: 24px;
		bottom: 24px;
		left: 23px;
		width: 1px;
		background: linear-gradient(var(--color-signal-cyan), var(--color-signal-green), var(--color-signal-amber));
		opacity: 0.62;
	}

	.infra-system-node {
		position: relative;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: var(--space-5, calc(var(--space-4) + var(--space-1)));
		align-items: start;
	}

	.infra-system-index {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		border: 1px solid var(--color-bg-muted);
		border-radius: var(--radius-full);
		background: var(--color-surface);
		color: var(--color-signal-cyan);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
	}

	.infra-system-copy {
		display: grid;
		gap: var(--space-3);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-bg-muted);
	}

	.infra-system-copy h3 {
		font-size: var(--text-2xl);
		line-height: 1.12;
	}

	.infra-system-copy p {
		max-width: 48ch;
		color: var(--color-text-secondary);
		line-height: 1.75;
	}

	.infra-disclosure {
		display: grid;
		gap: var(--space-3);
	}

	.infra-disclosure summary {
		cursor: pointer;
		width: fit-content;
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--color-text-primary);
	}

	.infra-disclosure summary::-webkit-details-marker {
		display: none;
	}

	.infra-system-status {
		width: fit-content;
		border-radius: var(--radius-full);
		background: color-mix(in srgb, var(--color-signal-cyan) 12%, var(--color-surface));
		color: var(--color-signal-cyan);
		padding: var(--space-1) var(--space-3);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.infra-evidence-grid {
		display: grid;
		gap: var(--space-4);
	}

	.infra-evidence-item {
		display: grid;
		gap: var(--space-3);
		padding-top: var(--space-5, calc(var(--space-4) + var(--space-1)));
		border-top: 1px solid var(--color-bg-muted);
	}

	.infra-evidence-item h3 {
		font-size: var(--text-lg);
		font-family: var(--font-body);
		font-weight: 500;
		color: var(--color-text-primary);
	}

	.infra-evidence-item p,
	.infra-note p:not(.section-kicker) {
		color: var(--color-text-secondary);
		line-height: 1.8;
	}

	.infra-note {
		display: grid;
		gap: var(--space-4);
		padding: var(--space-8);
		border-left: 4px solid var(--color-signal-green);
		background: color-mix(in srgb, var(--color-surface) 88%, transparent);
		box-shadow: 0 24px 80px color-mix(in srgb, var(--color-text-primary) 8%, transparent);
	}

	@media (min-width: 900px) {
		.infra-system-flow {
			grid-template-columns: repeat(5, minmax(0, 1fr));
			gap: 0;
		}

		.infra-system-flow::before {
			top: 24px;
			bottom: auto;
			left: 24px;
			right: 24px;
			width: auto;
			height: 1px;
			background: linear-gradient(90deg, var(--color-signal-cyan), var(--color-signal-green), var(--color-signal-amber));
		}

		.infra-system-node {
			grid-template-columns: 1fr;
			gap: var(--space-6);
			padding-right: var(--space-6);
		}

		.infra-system-copy {
			padding-top: var(--space-2);
			padding-bottom: 0;
			border-bottom: none;
		}

		.infra-system-copy h3 {
			font-size: var(--text-xl);
		}

		.infra-evidence-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}
</style>
