---
const sections = [
	{
		label: 'Hero',
		detail: 'Propuesta clara',
		status: 'Primer impacto',
	},
	{
		label: 'Servicios',
		detail: 'Oferta tecnica',
		status: 'Lectura rapida',
	},
	{
		label: 'Proyectos',
		detail: 'Evidencia filtrable',
		status: 'Prueba social',
	},
	{
		label: 'Contacto',
		detail: 'Brief y WhatsApp',
		status: 'Conversion',
	},
];

const stack = ['Astro', 'TypeScript', 'CSS'];

const signals = [
	{
		label: 'Performance',
		value: 'SSG',
	},
	{
		label: 'UX',
		value: 'One-page',
	},
	{
		label: 'CTA',
		value: 'Contacto directo',
	},
];
---

<div class="portfolio-visual" aria-label="Blueprint visual del portafolio M4 orientado a conversion">
	<div class="portfolio-visual__header">
		<div>
			<p>Sistema web</p>
			<strong>Portafolio M4 como flujo de conversion</strong>
		</div>
		<span>Astro build</span>
	</div>

	<div class="portfolio-visual__workspace">
		<section class="portfolio-visual__site-map" aria-label="Mapa del sitio">
			{sections.map((section, index) => (
				<article class="portfolio-visual__section-node">
					<span>{String(index + 1).padStart(2, '0')}</span>
					<h3>{section.label}</h3>
					<p>{section.detail}</p>
					<small>{section.status}</small>
				</article>
			))}
		</section>

		<aside class="portfolio-visual__inspector" aria-label="Stack y conversion">
			<div class="portfolio-visual__stack">
				<span>Stack</span>
				<div>
					{stack.map((tech) => (
						<strong>{tech}</strong>
					))}
				</div>
			</div>

			<div class="portfolio-visual__funnel">
				<span>Flujo CTA</span>
				<p>Visita -> proyecto -> brief -> contacto</p>
			</div>
		</aside>
	</div>

	<div class="portfolio-visual__signals">
		{signals.map((signal) => (
			<p>
				<span>{signal.label}</span>
				<strong>{signal.value}</strong>
			</p>
		))}
	</div>
</div>

<style>
	.portfolio-visual {
		display: grid;
		gap: var(--space-6);
		min-height: 100%;
		padding: var(--space-6);
		background:
			linear-gradient(90deg, color-mix(in srgb, var(--color-bg-muted) 30%, transparent) 1px, transparent 1px),
			linear-gradient(180deg, color-mix(in srgb, var(--color-bg-muted) 30%, transparent) 1px, transparent 1px),
			linear-gradient(135deg, color-mix(in srgb, var(--color-accent-subtle) 36%, transparent), transparent 58%),
			linear-gradient(180deg, var(--color-surface), var(--color-bg-subtle));
		background-size: 40px 40px, 40px 40px, auto, auto;
	}

	.portfolio-visual__header,
	.portfolio-visual__workspace,
	.portfolio-visual__signals {
		position: relative;
		z-index: 1;
	}

	.portfolio-visual__header {
		display: flex;
		justify-content: space-between;
		gap: var(--space-4);
		padding-bottom: var(--space-4);
		border-bottom: 1px solid var(--color-bg-muted);
	}

	.portfolio-visual__header div,
	.portfolio-visual__stack,
	.portfolio-visual__funnel {
		display: grid;
		gap: var(--space-2);
	}

	.portfolio-visual__header p,
	.portfolio-visual__header > span,
	.portfolio-visual__section-node span,
	.portfolio-visual__section-node small,
	.portfolio-visual__stack span,
	.portfolio-visual__funnel span,
	.portfolio-visual__signals span {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.portfolio-visual__header strong {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 4vw, var(--text-4xl));
		font-weight: 400;
		line-height: 1.05;
		color: var(--color-text-primary);
	}

	.portfolio-visual__header > span {
		height: fit-content;
		padding: var(--space-2) var(--space-3);
		border: 1px solid var(--color-bg-muted);
		background: color-mix(in srgb, var(--color-surface) 88%, transparent);
		color: var(--color-accent-text);
		white-space: nowrap;
	}

	.portfolio-visual__workspace {
		display: grid;
		grid-template-columns: minmax(0, 1.55fr) minmax(15rem, 0.65fr);
		gap: var(--space-4);
		align-items: stretch;
	}

	.portfolio-visual__site-map {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.portfolio-visual__section-node,
	.portfolio-visual__inspector,
	.portfolio-visual__signals p {
		border: 1px solid var(--color-bg-muted);
		background: color-mix(in srgb, var(--color-surface) 90%, transparent);
	}

	.portfolio-visual__section-node {
		display: grid;
		align-content: space-between;
		gap: var(--space-3);
		min-height: 10rem;
		padding: var(--space-4);
		border-bottom: 4px solid var(--color-accent);
	}

	.portfolio-visual__section-node h3 {
		font-family: var(--font-body);
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--color-text-primary);
	}

	.portfolio-visual__section-node p {
		color: var(--color-text-secondary);
		line-height: 1.55;
	}

	.portfolio-visual__section-node small {
		color: var(--color-signal-green);
	}

	.portfolio-visual__inspector {
		display: grid;
		align-content: space-between;
		gap: var(--space-4);
		padding: var(--space-4);
	}

	.portfolio-visual__stack div {
		display: grid;
		gap: var(--space-2);
	}

	.portfolio-visual__stack strong {
		padding: var(--space-3);
		border: 1px solid var(--color-bg-muted);
		background: var(--color-bg-subtle);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--color-accent-text);
	}

	.portfolio-visual__funnel {
		padding-top: var(--space-4);
		border-top: 1px solid var(--color-bg-muted);
	}

	.portfolio-visual__funnel p {
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	.portfolio-visual__signals {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.portfolio-visual__signals p {
		display: grid;
		gap: var(--space-1);
		padding: var(--space-4);
	}

	.portfolio-visual__signals strong {
		font-size: var(--text-sm);
		color: var(--color-text-primary);
	}

	@media (max-width: 900px) {
		.portfolio-visual__workspace,
		.portfolio-visual__signals {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 760px) {
		.portfolio-visual {
			gap: var(--space-4);
			padding: var(--space-4);
		}

		.portfolio-visual__header {
			display: grid;
		}

		.portfolio-visual__site-map,
		.portfolio-visual__signals {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.portfolio-visual__section-node,
		.portfolio-visual__inspector,
		.portfolio-visual__signals p {
			padding: var(--space-3);
		}

		.portfolio-visual__section-node {
			min-height: 8rem;
		}

		.portfolio-visual__section-node h3 {
			font-size: var(--text-sm);
		}
	}
</style>
