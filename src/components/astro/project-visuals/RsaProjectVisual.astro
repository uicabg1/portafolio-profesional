---
const flowSteps = [
	{
		label: '01',
		title: 'Primos base',
		value: 'p = 61 / q = 53',
	},
	{
		label: '02',
		title: 'Modulo publico',
		value: 'n = 3233',
	},
	{
		label: '03',
		title: 'Clave publica',
		value: 'e = 17',
	},
	{
		label: '04',
		title: 'Clave privada',
		value: 'd = 2753',
	},
];
---

<div class="rsa-visual" aria-label="Flujo visual de generacion, cifrado y descifrado RSA">
	<div class="rsa-visual__rail" aria-hidden="true">
		<span></span>
		<span></span>
		<span></span>
	</div>

	<div class="rsa-visual__header">
		<p>RSA / GMP</p>
		<strong>m^e mod n -> c -> c^d mod n</strong>
	</div>

	<div class="rsa-visual__flow">
		{flowSteps.map((step) => (
			<div class="rsa-visual__step">
				<span>{step.label}</span>
				<h3>{step.title}</h3>
				<p>{step.value}</p>
			</div>
		))}
	</div>

	<div class="rsa-visual__proof">
		<div>
			<span>Mensaje</span>
			<strong>65</strong>
		</div>
		<div>
			<span>Cifrado</span>
			<strong>2790</strong>
		</div>
		<div>
			<span>Descifrado</span>
			<strong>65</strong>
		</div>
	</div>

	<div class="rsa-visual__formula">
		<span>Validacion</span>
		<code>65 == pow(pow(65, e, n), d, n)</code>
	</div>
</div>

<style>
	.rsa-visual {
		position: relative;
		display: grid;
		gap: var(--space-6);
		min-height: 100%;
		padding: var(--space-6);
		overflow: hidden;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--color-bg) 92%, var(--color-accent-subtle)), transparent 42%),
			linear-gradient(180deg, var(--color-surface), var(--color-bg-subtle));
	}

	.rsa-visual__rail {
		position: absolute;
		inset: var(--space-4);
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-4);
		pointer-events: none;
		opacity: 0.42;
	}

	.rsa-visual__rail span {
		border-left: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);
		border-right: 1px solid color-mix(in srgb, var(--color-signal-cyan) 18%, transparent);
	}

	.rsa-visual__header,
	.rsa-visual__flow,
	.rsa-visual__proof,
	.rsa-visual__formula {
		position: relative;
		z-index: 1;
	}

	.rsa-visual__header {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: var(--space-4);
		padding-bottom: var(--space-4);
		border-bottom: 1px solid var(--color-bg-muted);
	}

	.rsa-visual__header p,
	.rsa-visual__header strong,
	.rsa-visual__step span,
	.rsa-visual__proof span,
	.rsa-visual__formula span,
	.rsa-visual__formula code {
		font-family: var(--font-mono);
	}

	.rsa-visual__header p,
	.rsa-visual__step span,
	.rsa-visual__proof span,
	.rsa-visual__formula span {
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.rsa-visual__header strong {
		max-width: 24rem;
		text-align: right;
		font-size: var(--text-sm);
		color: var(--color-text-primary);
	}

	.rsa-visual__flow {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.rsa-visual__step,
	.rsa-visual__proof > div,
	.rsa-visual__formula {
		border: 1px solid var(--color-bg-muted);
		background: color-mix(in srgb, var(--color-surface) 88%, transparent);
	}

	.rsa-visual__step {
		display: grid;
		gap: var(--space-2);
		min-height: 8.5rem;
		padding: var(--space-4);
	}

	.rsa-visual__step h3 {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-text-primary);
	}

	.rsa-visual__step p {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--color-accent-text);
		word-break: break-word;
	}

	.rsa-visual__proof {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.rsa-visual__proof > div {
		display: grid;
		gap: var(--space-1);
		padding: var(--space-4);
	}

	.rsa-visual__proof strong {
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: 400;
		color: var(--color-text-primary);
	}

	.rsa-visual__formula {
		display: grid;
		gap: var(--space-2);
		padding: var(--space-4);
		overflow: hidden;
	}

	.rsa-visual__formula code {
		display: block;
		overflow-x: auto;
		color: var(--color-signal-green);
		white-space: nowrap;
	}

	@media (max-width: 760px) {
		.rsa-visual {
			padding: var(--space-4);
		}

		.rsa-visual__header {
			display: grid;
		}

		.rsa-visual__header strong {
			text-align: left;
		}

		.rsa-visual__flow,
		.rsa-visual__proof {
			grid-template-columns: 1fr;
		}

		.rsa-visual__step {
			min-height: auto;
		}
	}
</style>
