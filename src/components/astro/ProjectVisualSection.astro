---
import IPv6ProjectVisual from './project-visuals/IPv6ProjectVisual.astro';
import NocProjectVisual from './project-visuals/NocProjectVisual.astro';
import PortfolioProjectVisual from './project-visuals/PortfolioProjectVisual.astro';
import RsaProjectVisual from './project-visuals/RsaProjectVisual.astro';

interface Props {
	projectSlug: string;
	title: string;
	summary: string;
	ogImage?: string;
}

const {
	projectSlug,
	title,
	summary,
	ogImage = '/og/default.svg',
} = Astro.props as Props;

const hasCustomVisual =
	projectSlug === 'rsa-en-c' ||
	projectSlug === 'migracion-ipv6' ||
	projectSlug === 'dashboard-noc' ||
	projectSlug === 'portafolio-m4';

const visualMetadataBySlug: Record<string, { eyebrow: string; title: string }> = {
	'rsa-en-c': {
		eyebrow: 'Laboratorio visual',
		title: 'Prueba criptografica',
	},
	'migracion-ipv6': {
		eyebrow: 'Mapa operativo',
		title: 'Transicion IPv6 controlada',
	},
	'dashboard-noc': {
		eyebrow: 'Cockpit operativo',
		title: 'Supervision NOC',
	},
	'portafolio-m4': {
		eyebrow: 'Blueprint de conversion',
		title: 'Arquitectura del sitio',
	},
};

const visualMetadata = visualMetadataBySlug[projectSlug] ?? {
	eyebrow: 'Visual del caso',
	title: 'Vista del caso',
};
---

<section class="project-visual-section reveal reveal-1" aria-labelledby={`visual-${projectSlug}`}>
	<div class="project-visual-copy">
		<p class="project-visual-kicker">{visualMetadata.eyebrow}</p>
		<h2 id={`visual-${projectSlug}`} class="project-visual-title">{visualMetadata.title}</h2>
	</div>

	<figure class="project-visual-frame" data-custom-visual={hasCustomVisual}>
		{projectSlug === 'rsa-en-c' && <RsaProjectVisual />}
		{projectSlug === 'migracion-ipv6' && <IPv6ProjectVisual />}
		{projectSlug === 'dashboard-noc' && <NocProjectVisual />}
		{projectSlug === 'portafolio-m4' && <PortfolioProjectVisual />}
		{!hasCustomVisual && (
			<img
				src={ogImage}
				alt={`Vista visual de ${title}`}
				loading="lazy"
				decoding="async"
			/>
		)}
		<figcaption>{summary}</figcaption>
	</figure>
</section>

<style>
	.project-visual-section {
		max-width: min(var(--container-max), 100%);
		margin: calc(var(--space-24) * -0.35) auto var(--space-24);
		display: grid;
		gap: var(--space-6);
	}

	.project-visual-copy {
		max-width: var(--container-prose);
		margin-inline: auto;
		display: grid;
		gap: var(--space-2);
	}

	.project-visual-kicker {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.project-visual-title {
		font-family: var(--font-body);
		font-size: var(--text-xl);
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.project-visual-frame {
		display: grid;
		overflow: hidden;
		border: 1px solid var(--color-bg-muted);
		border-radius: var(--radius-lg);
		background: var(--color-bg-subtle);
		box-shadow: 0 18px 70px color-mix(in srgb, var(--color-text-primary) 7%, transparent);
	}

	.project-visual-frame[data-custom-visual='true'] {
		min-height: 34rem;
	}

	.project-visual-frame img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		background: var(--color-bg-subtle);
	}

	.project-visual-frame figcaption {
		padding: var(--space-4) var(--space-6);
		border-top: 1px solid var(--color-bg-muted);
		font-size: var(--text-sm);
		line-height: 1.7;
		color: var(--color-text-secondary);
		background: color-mix(in srgb, var(--color-surface) 88%, transparent);
	}

	@media (max-width: 760px) {
		.project-visual-section {
			margin-top: calc(var(--space-24) * -0.2);
		}

		.project-visual-frame[data-custom-visual='true'] {
			min-height: auto;
		}

		.project-visual-frame figcaption {
			padding: var(--space-4);
		}
	}
</style>
